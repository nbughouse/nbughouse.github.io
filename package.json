{
	"name": "bughouse-n-player",
	"version": "1.0.0",
	"description": "bughouse allowing for multiple boards",
	"main": "dist/server/index.js",
	"type": "module",
	"scripts": {
		"build": "npm run build:shared && npm run build:fix-esm && npm run build:client && npm run build:server && npm run build:alias",
		"build:frontend": "npm run build:shared && npm run build:fix-esm && npm run build:client",
		"build:backend": "npm run build:shared && npm run build:fix-esm && npm run build:server && npm run build:alias",
		"build:pages": "npm run build:frontend && cp dist/public/index.html dist/public/404.html && touch dist/public/.nojekyll",
		"build:client": "vite build",
		"build:server": "cd server && tsc --build tsconfig.build.json",
		"build:shared": "cd shared && tsc --build",
		"build:fix-esm": "node scripts/fix-esm-relative-imports.mjs dist/shared",
		"build:alias": "node scripts/fix-esm-relative-imports.mjs dist/server",
		"dev": "concurrently --names \"server,vite\" --prefix-colors \"blue,magenta\" \"npm run dev:server\" \"npm run dev:client\"",
		"dev:server": "tsx watch --tsconfig server/tsconfig.json server/src/index.ts",
		"dev:client": "vite",
		"start": "npm run start:server",
		"start:all": "concurrently --names \"server,vite\" --prefix-colors \"blue,magenta\" \"npm run start:server\" \"npm run start:client\"",
		"start:server": "node dist/server/index.js",
		"start:client": "vite preview",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"express": "^4.22.2",
		"socket.io": "^4.8.1",
		"socket.io-client": "^4.8.1",
		"ws": "^8.13.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.17",
		"@types/node": "^20.19.41",
		"@types/ws": "^8.5.4",
		"concurrently": "^8.2.2",
		"tsc-alias": "^1.8.17",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.13"
	}
}
