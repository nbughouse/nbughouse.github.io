{
	"compilerOptions": {
		"target": "ES2020",
		"strict": true,
		"ignoreDeprecations": "6.0",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "node",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"files": [],
	"references": [
		{
			"path": "./shared"
		},
		{
			"path": "./server"
		},
		{
			"path": "./public"
		}
	]
}
